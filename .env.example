# ─────────────────────────────────────────────────────────────────────────────
# MaHaVi Restaurant SaaS — Environment Variables
# Copy this file to .env and fill in real values before starting the server.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string — Prisma uses this directly
DATABASE_URL=postgresql://user:password@localhost:5432/mahavi?schema=public

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Staff and member secrets MUST be different values — they serve separate auth contexts.
JWT_ACCESS_SECRET=replace_with_at_least_32_char_random_string_for_staff_access
JWT_REFRESH_SECRET=replace_with_at_least_32_char_random_string_for_staff_refresh
JWT_MEMBER_SECRET=replace_with_at_least_32_char_random_string_for_customer_members

# Token expiry — see https://github.com/vercel/ms for format
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_MEMBER_EXPIRES_IN=6h

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ── eSewa Payment Gateway ─────────────────────────────────────────────────────
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_VERIFY_URL=https://rc-epay.esewa.com.np/api/epay/transaction/status/

# ── Application URLs ──────────────────────────────────────────────────────────
# Used for OAuth redirects and CORS allowlist
FRONTEND_URL=http://localhost:5173
CUSTOMER_APP_URL=http://localhost:5174

# ── Business Rules ────────────────────────────────────────────────────────────
# Number of days after subscription expiry before access is fully cut off
SUBSCRIPTION_GRACE_DAYS=3
