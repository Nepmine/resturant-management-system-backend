BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
REMOTE_REF=$4

# ── Block direct push to main ─────────────────────────────────────────────────

if [ "$BRANCH" = "main" ] || echo "$REMOTE_REF" | grep -q "refs/heads/main"; then
  echo ""
  echo "  ┌─────────────────────────────────────────────────────────┐"
  echo "  │             Direct push to main is restricted 🔒         │"
  echo "  └─────────────────────────────────────────────────────────┘"
