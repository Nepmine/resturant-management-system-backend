  echo "  ──────────────────────────────────────────────────────────"
  echo ""
  echo "    1. Create a feature branch from your current work:"
  echo ""
  echo "         git checkout -b feature/your-branch-name"
  echo ""
  echo "    2. Push the feature branch:"
  echo ""
  echo "         git push origin feature/your-branch-name"
  echo ""
  echo "    3. Open a Pull Request on GitHub to merge into main."
  echo ""
  echo "  ──────────────────────────────────────────────────────────"
  echo ""
  exit 1
fi

# ── Branch naming check ───────────────────────────────────────────────────────

VALID_PATTERN='^(master|develop|dev|staging)$|^(feature|fix|hotfix|release|chore|refactor)/[a-z0-9][a-z0-9-]*[a-z0-9]$'

if echo "$BRANCH" | grep -qE "$VALID_PATTERN"; then
  exit 0
fi

echo ""
echo "  ┌─────────────────────────────────────────────────────────┐"
echo "  │                   Push Blocked 🚫                        │"
echo "  └─────────────────────────────────────────────────────────┘"
echo ""
echo "  Your branch name  →  \"$BRANCH\""
